# Copy to `.env` and edit before first `docker compose up -d`.

# Fully-qualified domain name pointing at your VPS.
# The DNS A record for this host MUST already resolve to the VPS public IP
# before starting Caddy, or Let's Encrypt validation will fail.
DOMAIN=deckbuilder.example.com

# Email registered with Let's Encrypt / ZeroSSL for the ACME account.
# Used by Caddy for cert expiry notifications. Use a real address.
ACME_EMAIL=you@example.com

# --- Optional knobs (sensible defaults; uncomment to override) ---
# Already wired into docker-compose.yml → app environment.
# DB_PATH=/data/magic.db

# --- Vercel + Turso (production) ---
# Set BOTH in Vercel → Project → Settings → Environment Variables.
# Required when deploying to Vercel; ignored by local/Docker dev.
#
# Get them with:
#   turso db show magic-deck-builder --url
#   turso db tokens create magic-deck-builder
#
# The URL MUST be the libsql:// form (not the https:// dashboard URL).
TURSO_DATABASE_URL=libsql://magic-deck-builder-<your-cluster>.turso.io
TURSO_AUTH_TOKEN=
